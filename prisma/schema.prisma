generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id               String  @id @default(cuid())
  name             String
  legalName        String?
  dba              String?
  organizationType String

  primaryContact String
  email          String
  phone          String?
  website        String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?

  accreditations   String[]
  ownerClerkUserId String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facilities Facility[]
  users      User[]
  evidence   Evidence[]
  standards  Standard[]
}

model Facility {
  id           String @id @default(cuid())
  name         String
  facilityType String

  primaryAccreditor      String?
  cmsCertificationNumber String?
  facilityAdministrator  String?
  medicalDirector        String?
  safetyOfficer          String?
  timeZone               String?
  facilityAddress        String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  evidence Evidence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model User {
  id        String  @id
  email     String  @unique
  firstName String?
  lastName  String?

  role             String @default("Staff")
  accessScope      String @default("All Facilities")
  invitationStatus String @default("Active")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Evidence {
  id          String  @id @default(cuid())
  title       String
  description String?
  fileName    String
  fileUrl     String?
  fileType    String?
  fileSize    Int?
  extractedText  String? @db.Text
  analysisStatus String  @default("Pending")
  analysisError  String? @db.Text
    analysisDocumentType         String?
  analysisDepartment           String?
  analysisConfidence           Float?
  analysisEvidenceQuality Float?
  analysisSurveyReadiness Float?
  analysisRiskLevel String?
  analysisStrengths String[]
  analysisRecommendations String[]
  analysisExecutiveSummary String? @db.Text
  analysisRecommendedStandards String[]
  analysisMissingEvidence      String[]
  analysisSummary              String? @db.Text
  category       String?
  status         String    @default("Draft")
  ownerName      String?
  expirationDate DateTime?
  uploadedAt     DateTime  @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  facilityId String?
  facility   Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  standardMappings EvidenceStandard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([facilityId])
  @@index([status])
}

model Standard {
  id String @id @default(cuid())

  accreditor  String
  code        String
  title       String
  chapter     String?
  description String?
  requirement String?

  version       String?
  effectiveDate DateTime?
  category      String?
  riskLevel     String?
  status        String    @default("Active")

  sourceUrl String?
  isCustom  Boolean @default(false)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  evidenceMappings EvidenceStandard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([accreditor])
  @@index([code])
  @@index([category])
  @@index([status])
}

model EvidenceStandard {
  id String @id @default(cuid())

  evidenceId String
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  standardId String
  standard   Standard @relation(fields: [standardId], references: [id], onDelete: Cascade)

  mappingSource String    @default("Manual")
  confidence    Float?
  notes         String?
  isVerified    Boolean   @default(false)
  verifiedBy    String?
  verifiedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([evidenceId, standardId])
  @@index([evidenceId])
  @@index([standardId])
  @@index([isVerified])
}
